# Reference stand — strong secrets, production hardening (config-only fixes)

PORT=3002
TEAM=dev
NODE_ENV=production
EXPOSE_DEBUG=false

# V1.1 fixed: strong JWT secret (32+ bytes)
JWT_SECRET=ref-helpdesk-jwt-9f3c2e1a7b8d4e6f0a1b2c3d4e5f6789
JWT_COOKIE_NAME=hd_token

# V1.4 fixed: explicit origin
CORS_ORIGIN=https://helpdesk.local
CORS_CREDENTIALS=true

# V1.6 fixed: helmet on
SECURITY_HEADERS=on

# V1.5 fixed: strong admin password
SEED_ADMIN_PASSWORD=RefAdm!9f3c2e1a7b8d4e6f

# V1.9 fixed: only public assets
SERVE_STATIC_ROOT=./public

# Debug canary unused when EXPOSE_DEBUG=false
DEBUG_CANARY_FLAG=

FLAG_FILE_PATH=./flags/app1.flag

# Local compose uses shared DB user; k8s uses least-privilege from reference/db/init.sql (V1.7)
DATABASE_URL=postgres://helpdesk:helpdesk@127.0.0.1:5433/helpdesk
LOG_LEVEL=info
