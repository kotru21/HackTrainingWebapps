{
  "name": "@hacktraining/app1-helpdesk",
  "version": "0.0.1",
  "private": true,
  "description": "Helpdesk training app — shared src for vulnerable/ and reference/ (Phase 1)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:vulnerable": "cross-env HELPDESK_ENV_FILE=./vulnerable/.env tsx src/index.ts",
    "dev:reference": "cross-env HELPDESK_ENV_FILE=./reference/.env tsx src/index.ts"
  },
  "dependencies": {
    "@hacktraining/shared": "0.0.1",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ejs": "3.1.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.2",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.4",
    "typescript": "^7.0.2"
  }
}
