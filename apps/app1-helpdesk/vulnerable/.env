# INTENTIONALLY WEAK — training only
# app1-helpdesk vulnerable stand (V1.1–V1.9)

PORT=3001
TEAM=dev
NODE_ENV=development
EXPOSE_DEBUG=true

# V1.1 weak JWT secret
JWT_SECRET=secret
JWT_COOKIE_NAME=hd_token

# V1.4 CORS wildcard + credentials
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# V1.6 helmet disabled
SECURITY_HEADERS=off

# V1.5 default admin password
SEED_ADMIN_PASSWORD=admin123

# V1.9 serve project root (leaks .env / .git)
SERVE_STATIC_ROOT=.

# V1.3 debug canary (32 hex)
DEBUG_CANARY_FLAG=TRN{deb06111111111111111111111111111}

# Local path for RCE flag file (V1.2); planter uses /flags/app1.flag in k8s
FLAG_FILE_PATH=./flags/app1.flag

DATABASE_URL=postgres://helpdesk:helpdesk@127.0.0.1:5433/helpdesk
LOG_LEVEL=info
