# ==============================================================================
#  Конфиг стенда app1 (Helpdesk) — правьте ПРЯМО ЗДЕСЬ в code-server.
#  Сохранение файла перезапускает приложение автоматически (tsx watch).
#  Задача Blue: закрыть уязвимости, поменяв значения ниже, не сломав работу стенда.
#  (PORT, подключение к БД и т.п. берутся из инфраструктуры и здесь не трогаются.)
# ==============================================================================

# V1.3 — debug-эндпоинт /internal/debug сливает конфиг и флаг. Закрыть: false
EXPOSE_DEBUG=true

# V1.9 — статика отдаётся из корня проекта (утечка .env/.git). Закрыть: ./public
SERVE_STATIC_ROOT=.

# V1.4 — CORS отражает любой Origin + пускает credentials. Закрыть: конкретный origin
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# V1.6 — security-заголовки (CSP/HSTS/...) выключены. Закрыть: on
SECURITY_HEADERS=off

# V1.1 — слабый JWT-секрет (подделка admin-токена). Закрыть: длинный случайный
JWT_SECRET=secret

# V1.5 — дефолтный пароль администратора. Закрыть: сменить на стойкий
SEED_ADMIN_PASSWORD=admin123
