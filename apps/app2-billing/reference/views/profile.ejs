<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Profile — Billing</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="top">
    <a class="brand" href="/">Acme Billing</a>
    <nav>
      <a href="/profile">Profile</a>
      <% if (user.role === 'admin') { %><a href="/admin">Admin</a><% } %>
    </nav>
  </header>
  <main>
    <h1><%= profile.display_name || profile.username %></h1>
    <p class="muted">@<%= profile.username %> · <%= profile.role %></p>
    <% if (profile.avatar_url) { %>
      <p>Avatar URL: <%= profile.avatar_url %></p>
    <% } %>
    <h2>Bio</h2>
    <!-- V2.3 fix: escaped bio -->
    <div class="card bio"><%= profile.bio %></div>
  </main>
</body>
</html>
