.env
.env.*
!.env.example
!apps/**/vulnerable/.env
!apps/**/reference/.env
secrets
*.pem
*.key
kubeconfig*

# Round artifacts & local data
artifacts
coverage
.nyc_output
logs
*.log

# Deploy scripts not needed inside app images
scripts
tools/attacker-scripts

# OS
.DS_Store
Thumbs.db
