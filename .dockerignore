# Git / VCS
.git
.gitignore
.gitattributes

# Docs & IDE (not needed in images)
docs
.cursor
.vscode
.idea
*.md
!apps/**/reference/SOLUTION.md

# Dependencies & build (rebuilt in image)
**/node_modules
**/dist
