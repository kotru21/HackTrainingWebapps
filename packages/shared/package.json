{
  "name": "@hacktraining/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared flag constants, log event types, and pino logger wrapper",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
