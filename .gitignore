# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment / secrets (platform secrets never committed)
.env
.env.*
!.env.example
!.env.vulnerable.example
# Training stand env files are intentional (weak secrets marked in-file)
!apps/**/vulnerable/.env
!apps/**/reference/.env
secrets/
*.pem
*.key
kubeconfig*
!-deploy/**/kubeconfig.example

# Logs & runtime
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Round artifacts (collected by collect-logs.sh)
artifacts/**
!artifacts/.gitkeep

# Local planted flag files (created at runtime)
apps/**/flags/
**/flags/*.flag

# IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db

# Coverage / test
coverage/
.nyc_output/

# Docker
*.tar

# Local k3s / tooling
.k3s/
.kube/
